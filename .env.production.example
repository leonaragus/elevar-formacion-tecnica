# Variables de entorno para producción (Vercel)
# Estas variables deben configurarse en el dashboard de Vercel

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Autenticación
ADMIN_TOKEN=tu-token-secreto-para-admin

# Notificaciones Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=tu-vapid-public-key-aqui
VAPID_PRIVATE_KEY=tu-vapid-private-key-aqui
VAPID_SUBJECT=mailto:tu-email@ejemplo.com

# API para cron jobs
CRON_API_KEY=tu-cron-api-key-secreto