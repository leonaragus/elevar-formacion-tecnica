<Window x:Class="InstitutoFormacionTecnica.RegisterPaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InstitutoFormacionTecnica"
        mc:Ignorable="d"
        Title="Registrar Pago" Height="450" Width="550"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary Source="Resources/Styles.xaml"/>
        <ResourceDictionary Source="Resources/ThemeColors.xaml"/>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Registrar Pago" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}"/>
            <TextBlock Text="Complete los datos del pago a registrar" FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,5,0,0"/>
        </StackPanel>
        
        <!-- Formulario -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Datos del Pago -->
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Datos del Pago" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <StackPanel Margin="0,0,20,0" Width="250">
                            <TextBlock Text="Estudiante" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                            <ComboBox x:Name="StudentComboBox" Height="40" FontSize="14" Padding="12,8" BorderBrush="{StaticResource BorderLight}" BorderThickness="1"/>
                        </StackPanel>
                        
                        <StackPanel Width="250">
                            <TextBlock Text="Curso" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                            <ComboBox x:Name="CourseComboBox" Height="40" FontSize="14" Padding="12,8" BorderBrush="{StaticResource BorderLight}" BorderThickness="1"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <StackPanel Margin="0,0,20,0" Width="250">
                            <TextBlock Text="Monto (ARS)" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                            <TextBox x:Name="AmountTextBox" Height="40" FontSize="14" Padding="12,8" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" InputScope="Number"/>
                        </StackPanel>
                        
                        <StackPanel Width="250">
                            <TextBlock Text="Fecha de Pago" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                            <DatePicker x:Name="PaymentDatePicker" Height="40" FontSize="14" BorderBrush="{StaticResource BorderLight}" BorderThickness="1"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Concepto" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                        <TextBox x:Name="ConceptTextBox" Height="60" FontSize="14" Padding="12,8" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Datos de Facturación -->
                <StackPanel Margin="0,0,0,25">
                    <TextBlock Text="Datos de Facturación" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryColor}" Margin="0,0,0,15"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <StackPanel Margin="0,0,20,0" Width="250">
                            <TextBlock Text="Tipo de Factura" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                            <ComboBox x:Name="InvoiceTypeComboBox" Height="40" FontSize="14" Padding="12,8" BorderBrush="{StaticResource BorderLight}" BorderThickness="1">
                                <ComboBoxItem Content="A"/>
                                <ComboBoxItem Content="B"/>
                                <ComboBoxItem Content="C"/>
                                <ComboBoxItem Content="Consumidor Final"/>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Width="250">
                            <TextBlock Text="N° de Factura" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                            <TextBox x:Name="InvoiceNumberTextBox" Height="40" FontSize="14" Padding="12,8" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" InputScope="Number"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="CUIT/CUIL" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,5"/>
                        <TextBox x:Name="TaxIdTextBox" Height="40" FontSize="14" Padding="12,8" BorderBrush="{StaticResource BorderLight}" BorderThickness="1" InputScope="Number"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Botones -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="CancelPaymentButton" Content="Cancelar" Style="{StaticResource ButtonSecondary}" Width="100" Margin="0,0,10,0" Click="CancelPaymentButton_Click"/>
            <Button x:Name="RegisterPaymentButton" Content="Registrar Pago" Style="{StaticResource ButtonPrimary}" Width="140" Click="RegisterPaymentButton_Click"/>
        </StackPanel>
    </Grid>
</Window>