<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Estilos de ventanas principales -->
    <Style x:Key="MainWindowStyle" TargetType="Window">
        <Setter Property="Width" Value="1200"/>
        <Setter Property="Height" Value="800"/>
        <Setter Property="MinWidth" Value="1000"/>
        <Setter Property="MinHeight" Value="600"/>
        <Setter Property="WindowStartupLocation" Value="CenterScreen"/>
        <Setter Property="ResizeMode" Value="CanResize"/>
        <Setter Property="Background" Value="#f8fafc"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Window">
                    <Border Background="{TemplateBinding Background}" BorderBrush="#e2e8f0" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Header -->
                            <Border Grid.Row="0" Background="#ffffff" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1" Padding="20,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="pack://application:,,,/Resources/logo.png" Width="40" Height="40" Margin="0,0,15,0"/>
                                        <TextBlock Text="Panel de Control" FontSize="20" FontWeight="Bold" Foreground="#1e293b" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Width="30" Height="30" Background="Transparent" BorderThickness="0" Margin="5">
                                            <TextBlock Text="🔔" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                        <Button Width="30" Height="30" Background="Transparent" BorderThickness="0" Margin="5">
                                            <TextBlock Text="⚙️" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <!-- Content -->
                            <ContentPresenter Grid.Row="1" Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"/>
                            <!-- Footer -->
                            <Border Grid.Row="2" Background="#f8fafc" BorderBrush="#e2e8f0" BorderThickness="1,1,0,0" Padding="15,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Elevar Formación Técnica - Panel de Control" FontSize="12" Foreground="#64748b" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" FontSize="12" Foreground="#64748b" VerticalAlignment="Center">
                                        <Run Text="2025"/>
                                        <Run Text=" ©"/>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
