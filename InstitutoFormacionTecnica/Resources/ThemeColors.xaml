<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Colores del tema -->
    <Color x:Key="PrimaryColor">#2563eb</Color>
    <Color x:Key="PrimaryColorLight">#3b82f6</Color>
    <Color x:Key="PrimaryColorDark">#1d4ed8</Color>
    <Color x:Key="SecondaryColor">#10b981</Color>
    <Color x:Key="SecondaryColorLight">#16a34a</Color>
    <Color x:Key="SecondaryColorDark">#059669</Color>
    <Color x:Key="WarningColor">#f59e0b</Color>
    <Color x:Key="WarningColorLight">#eab308</Color>
    <Color x:Key="WarningColorDark">#d97706</Color>
    <Color x:Key="DangerColor">#ef4444</Color>
    <Color x:Key="DangerColorLight">#f97316</Color>
    <Color x:Key="DangerColorDark">#dc2626</Color>
    <Color x:Key="InfoColor">#3b82f6</Color>
    <Color x:Key="InfoColorLight">#60a5fa</Color>
    <Color x:Key="InfoColorDark">#2563eb</Color>
    <Color x:Key="SuccessColor">#10b981</Color>
    <Color x:Key="SuccessColorLight">#34d399</Color>
    <Color x:Key="SuccessColorDark">#059669</Color>
    <Color x:Key="BackgroundLight">#f1f5f9</Color>
    <Color x:Key="BackgroundDark">#1e293b</Color>
    <Color x:Key="SurfaceLight">#ffffff</Color>
    <Color x:Key="SurfaceDark">#334155</Color>
    <Color x:Key="TextPrimary">#1e293b</Color>
    <Color x:Key="TextSecondary">#64748b</Color>
    <Color x:Key="TextMuted">#94a3b8</Color>
    <Color x:Key="BorderLight">#e2e8f0</Color>
    <Color x:Key="BorderDark">#334155</Color>
    <Color x:Key="ShadowColor">#000000</Color>
    <!-- Gradientes -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
        <GradientStop Color="{StaticResource PrimaryColorLight}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SecondaryGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource SecondaryColor}" Offset="0"/>
        <GradientStop Color="{StaticResource SecondaryColorLight}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="WarningGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource WarningColor}" Offset="0"/>
        <GradientStop Color="{StaticResource WarningColorLight}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource DangerColor}" Offset="0"/>
        <GradientStop Color="{StaticResource DangerColorLight}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="InfoGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource InfoColor}" Offset="0"/>
        <GradientStop Color="{StaticResource InfoColorLight}" Offset="1"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource SuccessColor}" Offset="0"/>
        <GradientStop Color="{StaticResource SuccessColorLight}" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>