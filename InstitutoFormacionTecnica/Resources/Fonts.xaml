<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!-- Fuentes -->
    <FontFamily x:Key="MainFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="SecondaryFontFamily">Segoe UI Semibold</FontFamily>
    <FontFamily x:Key="TitleFontFamily">Segoe UI Bold</FontFamily>
    <FontFamily x:Key="IconFontFamily">Segoe MDL2 Assets</FontFamily>
    
    <!-- Tamaños de fuente -->
    <sys:Double x:Key="FontSizeXS">10</sys:Double>
    <sys:Double x:Key="FontSizeSM">12</sys:Double>
    <sys:Double x:Key="FontSizeBase">14</sys:Double>
    <sys:Double x:Key="FontSizeLG">16</sys:Double>
    <sys:Double x:Key="FontSizeXL">18</sys:Double>
    <sys:Double x:Key="FontSize2XL">20</sys:Double>
    <sys:Double x:Key="FontSize3XL">24</sys:Double>
    <sys:Double x:Key="FontSize4XL">28</sys:Double>
</ResourceDictionary>
