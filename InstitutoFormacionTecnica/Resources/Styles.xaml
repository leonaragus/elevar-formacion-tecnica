<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Efectos visuales -->
    <DropShadowEffect x:Key="ButtonShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="{StaticResource ShadowColor}"/>
    <DropShadowEffect x:Key="CardShadow" BlurRadius="10" ShadowDepth="3" Opacity="0.1" Color="{StaticResource ShadowColor}"/>
    <DropShadowEffect x:Key="DialogShadow" BlurRadius="15" ShadowDepth="5" Opacity="0.3" Color="{StaticResource ShadowColor}"/>
    <DropShadowEffect x:Key="HeaderShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.5" Color="{StaticResource ShadowColor}"/>
    <!-- Estilos de texto -->
    <Style x:Key="Text.Header" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>
    <Style x:Key="Text.SubHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>
    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>
    <Style x:Key="Text.Muted" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>
    <!-- Estilos de botones -->
    <Style x:Key="Button.Primary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Opacity="{TemplateBinding Opacity}"
                            Effect="{StaticResource ButtonShadow}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryColorLight}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryColorDark}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="Button.Secondary" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BackgroundLight}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Opacity="{TemplateBinding Opacity}"
                            Effect="{StaticResource ButtonShadow}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BackgroundDark}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource BackgroundDark}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <!-- Estilos de bordes -->
    <Style x:Key="Border.Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceLight}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource SurfaceDark}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderDark}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <!-- Estilos de controles -->
    <Style x:Key="TextBox.Default" TargetType="TextBox">
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource SurfaceLight}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="ComboBox.Default" TargetType="ComboBox">
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource SurfaceLight}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="DatePicker.Default" TargetType="DatePicker">
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource SurfaceLight}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>