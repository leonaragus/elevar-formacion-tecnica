<Window x:Class="InstitutoFormacionTecnica.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InstitutoFormacionTecnica"
        mc:Ignorable="d"
        Title="Elevar Formación Técnica - Panel de Control" Height="800" Width="1200"
        MinHeight="600" MinWidth="800"
        Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary Source="Resources/Styles.xaml"/>
        <ResourceDictionary Source="Resources/ThemeColors.xaml"/>
        <ResourceDictionary Source="Resources/NotificationStyles.xaml"/>
        
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
        
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceLight}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="10"/>
        </Style>
        
        <Style x:Key="ButtonPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                Effect="{StaticResource ButtonShadow}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ButtonSecondary" TargetType="Button">
            <Setter Property="Background" Value="#f1f5f9"/>
            <Setter Property="Foreground" Value="#2c5282"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#cbd5e1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#2563eb" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Icono SVG simulado -->
                    <Viewbox Width="40" Height="40" Margin="0,0,15,0">
                        <Path Data="M12 2L1 21h22L12 2zm0 3.99L19.53 19H4.47L12 5.99zM11 16h2v2h-2zm0-6h2v4h-2z" 
                              Fill="White" />
                    </Viewbox>
                    <TextBlock Text="Elevar Formación Técnica" 
                               Style="{StaticResource HeaderStyle}">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                    <TextBlock x:Name="StatusText" Text="Conectado" FontSize="14" Foreground="White" Margin="0,0,20,0"/>
                    <Button x:Name="RefreshButton" Content="↻ Actualizar" Style="{StaticResource ButtonSecondary}" Click="RefreshButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Dashboard Cards -->
                <Grid Grid.Row="0" Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="👥 1,250" FontSize="32" FontWeight="Bold" Foreground="#2563eb"/>
                            <TextBlock Text="Estudiantes" FontSize="16" Foreground="#64748b" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="📚 45" FontSize="32" FontWeight="Bold" Foreground="#10b981"/>
                            <TextBlock Text="Cursos Activos" FontSize="16" Foreground="#64748b" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="💰 $45,000" FontSize="32" FontWeight="Bold" Foreground="#f59e0b"/>
                            <TextBlock Text="Ingresos Mensuales" FontSize="16" Foreground="#64748b" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="✅ 92%" FontSize="32" FontWeight="Bold" Foreground="#3b82f6"/>
                            <TextBlock Text="Satisfacción" FontSize="16" Foreground="#64748b" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
                
                <!-- Quick Actions -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Acciones Rápidas" FontSize="18" FontWeight="Bold" Foreground="#1e293b" Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="📚 Nuevo Curso" Style="{StaticResource ButtonPrimary}" Margin="0,0,10,0" Click="NewCourseButton_Click"/>
                            <Button Content="👥 Nuevo Estudiante" Style="{StaticResource ButtonPrimary}" Margin="0,0,10,0" Click="NewStudentButton_Click"/>
                            <Button Content="💰 Registrar Pago" Style="{StaticResource ButtonPrimary}" Click="RegisterPaymentButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Solicitudes Pendientes -->
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Solicitudes de Ingreso Pendientes" FontSize="18" FontWeight="Bold" Foreground="#1e293b" Margin="0,0,0,15"/>
                        <ListView x:Name="PendingList" Margin="0,0,0,10">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding CursoId}" FontSize="14" Foreground="#1e293b"/>
                                        <TextBlock Grid.Column="1" Text="{Binding UserId}" FontSize="12" Foreground="#64748b" Margin="10,0,0,0"/>
                                        <Button Grid.Column="2" Content="Aprobar" Style="{StaticResource ButtonPrimary}" Margin="10,0,0,0" Click="ApprovePending_Click"/>
                                        <Button Grid.Column="3" Content="Rechazar" Style="{StaticResource ButtonSecondary}" Margin="10,0,0,0" Click="RejectPending_Click"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Actualizar Pendientes" Style="{StaticResource ButtonSecondary}" Click="RefreshPendings_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Recent Activity -->
                <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Actividad Reciente" FontSize="18" FontWeight="Bold" Foreground="#1e293b" Margin="0,0,0,15"/>
                        <ListView x:Name="RecentActivityList" Margin="0,0,0,10">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                        <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Description}" FontSize="14" Foreground="#64748b" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Time}" FontSize="12" Foreground="#94a3b8" VerticalAlignment="Center" Margin="20,0,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
                
                <!-- System Info -->
                <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Información del Sistema" FontSize="18" FontWeight="Bold" Foreground="#1e293b" Margin="0,0,0,15"/>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Versión:" Width="120" Foreground="#64748b"/>
                                <TextBlock Text="1.0.0" Foreground="#1e293b"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Base de Datos:" Width="120" Foreground="#64748b"/>
                                <TextBlock x:Name="DatabaseStatus" Text="Conectada" Foreground="#10b981"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Ultimo Backup:" Width="120" Foreground="#64748b"/>
                                <TextBlock Text="Hace 2 horas" Foreground="#1e293b"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
        
        <!-- Footer -->
        <Border Grid.Row="2" Background="#f1f5f9" Padding="15" BorderBrush="#e2e8f0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="© 2025 Instituto de Formación Técnica" FontSize="12" Foreground="#64748b"/>
                <TextBlock Text=" | " FontSize="12" Foreground="#cbd5e1" Margin="10,0"/>
                <TextBlock Text="Versión 1.0.0" FontSize="12" Foreground="#64748b"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
