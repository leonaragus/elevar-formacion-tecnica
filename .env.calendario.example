# Variables de entorno para el sistema de calendario

# API key para ejecutar recordatorios automáticos (cambia esta clave por una segura)
CRON_API_KEY=mi_clave_secreta_super_segura_12345

# Service role key de Supabase (necesario para el servidor de recordatorios)
# Esta key tiene acceso completo a la base de datos, mantenla segura
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_de_supabase_aqui

# Configuración de recordatorios (opcional)
# Días antes de la entrega para enviar recordatorios (separados por comas)
DIAS_RECORDATORIOS=7,3,1

# Hora del día para enviar recordatorios (formato 24h, por defecto 09:00)
HORA_RECORDATORIOS=09:00